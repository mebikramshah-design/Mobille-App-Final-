# ─── Gmail (for guest email OTP) ───────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate a password for "Mail" / "Other device" — use that below (NOT your real password)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Twilio (for employee SMS OTP) ─────────────────────────────────────────────
# Sign up at twilio.com → Console Dashboard shows Account SID + Auth Token
# Get a phone number: twilio.com/console/phone-numbers/incoming
# For Qatar numbers use +974XXXXXXXX format
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
